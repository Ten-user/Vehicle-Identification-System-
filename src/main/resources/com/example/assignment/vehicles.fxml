<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.VehiclesController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="Vehicle Management" styleClass="module-title"/>
                <Label text="Workshop Module — Register and manage vehicles" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.65" style="-fx-background-color: #F5F6FA;">
            <!-- LEFT: Table -->
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search vehicles..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                    <Label fx:id="statusLabel" text="" styleClass="info-label"/>
                </HBox>
                <TableView fx:id="vehicleTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId"        text="ID"          prefWidth="45"/>
                        <TableColumn fx:id="colRegNumber" text="Reg. No."    prefWidth="100"/>
                        <TableColumn fx:id="colMake"      text="Make"        prefWidth="80"/>
                        <TableColumn fx:id="colModel"     text="Model"       prefWidth="90"/>
                        <TableColumn fx:id="colYear"      text="Year"        prefWidth="55"/>
                        <TableColumn fx:id="colColor"     text="Color"       prefWidth="70"/>
                        <TableColumn fx:id="colOwner"     text="Owner"       prefWidth="120"/>
                        <TableColumn fx:id="colEngine"    text="Engine No."  prefWidth="100"/>
                        <TableColumn fx:id="colChassis"   text="Chassis No." prefWidth="100"/>
                        <TableColumn fx:id="colStolen"    text="Status"      prefWidth="80"/>
                    </columns>
                    <placeholder><Label text="No vehicles found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <!-- RIGHT: Form + vehicle image -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <!-- Vehicle image preview -->
                    <VBox alignment="CENTER" spacing="8"
                          style="-fx-background-color: #F8F9FC; -fx-background-radius: 10;
                                 -fx-border-color: #E8EAEF; -fx-border-radius: 10; -fx-padding: 12;">
                        <ImageView fx:id="vehicleImageView" fitWidth="260" fitHeight="150"
                                   preserveRatio="true" smooth="true"/>
                        <Label fx:id="vehicleImageLabel" text="Select a vehicle to see image"
                               style="-fx-text-fill: #AABBCC; -fx-font-size: 11px;"/>
                        <Button fx:id="uploadImageBtn" text="Upload Image" onAction="#handleUploadImage"
                                styleClass="btn-secondary" maxWidth="Infinity"/>
                    </VBox>

                    <Label text="Vehicle Details" styleClass="form-section-title"/>
                    <Label text="Registration Number" styleClass="form-label"/>
                    <TextField fx:id="regNumberField" styleClass="form-field" promptText="e.g. GP 123 456" maxWidth="Infinity"/>
                    <Label text="Make" styleClass="form-label"/>
                    <TextField fx:id="makeField" styleClass="form-field" promptText="e.g. Toyota" maxWidth="Infinity"/>
                    <Label text="Model" styleClass="form-label"/>
                    <TextField fx:id="modelField" styleClass="form-field" promptText="e.g. Hilux" maxWidth="Infinity"/>
                    <Label text="Year" styleClass="form-label"/>
                    <TextField fx:id="yearField" styleClass="form-field" promptText="e.g. 2022" maxWidth="Infinity"/>
                    <Label text="Color" styleClass="form-label"/>
                    <TextField fx:id="colorField" styleClass="form-field" promptText="e.g. White" maxWidth="Infinity"/>
                    <Label text="Owner" styleClass="form-label"/>
                    <ComboBox fx:id="ownerCombo" styleClass="combo-box" promptText="Select owner" maxWidth="Infinity"/>
                    <Label text="Engine Number" styleClass="form-label"/>
                    <TextField fx:id="engineNumberField" styleClass="form-field" promptText="Engine number" maxWidth="Infinity"/>
                    <Label text="Chassis Number" styleClass="form-label"/>
                    <TextField fx:id="chassisNumberField" styleClass="form-field" promptText="Chassis number" maxWidth="Infinity"/>
                    <Separator/>
                    <HBox spacing="8">
                        <Button fx:id="saveBtn"   text="Add Vehicle" onAction="#handleSave"   styleClass="btn-primary"/>
                        <Button fx:id="updateBtn" text="Update"      onAction="#handleUpdate" styleClass="btn-warning"/>
                        <Button fx:id="deleteBtn" text="Delete"      onAction="#handleDelete" styleClass="btn-danger"/>
                        <Button fx:id="clearBtn"  text="Clear"       onAction="#handleClear"  styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
