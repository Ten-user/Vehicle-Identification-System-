<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.InsuranceController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="Insurance Policies" styleClass="module-title"/>
                <Label text="Insurance Module — Policy management and tracking (Lesotho)" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.65" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search policies..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                </HBox>
                <TableView fx:id="insuranceTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="45"/>
                        <TableColumn fx:id="colVehicle" text="Vehicle" prefWidth="130"/>
                        <TableColumn fx:id="colCustomer" text="Customer" prefWidth="120"/>
                        <TableColumn fx:id="colPolicy" text="Policy No." prefWidth="110"/>
                        <TableColumn fx:id="colProvider" text="Provider" prefWidth="110"/>
                        <TableColumn fx:id="colCoverage" text="Coverage" prefWidth="150"/>
                        <TableColumn fx:id="colStart" text="Start" prefWidth="90"/>
                        <TableColumn fx:id="colEnd" text="End" prefWidth="90"/>
                        <TableColumn fx:id="colPremium" text="Premium (M)" prefWidth="100"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="75"/>
                    </columns>
                    <placeholder><Label text="No records found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <Label text="Policy Details" styleClass="form-section-title"/>

                    <Label text="Vehicle" styleClass="form-label"/>
                    <ComboBox fx:id="vehicleCombo" styleClass="combo-box" promptText="Select vehicle" maxWidth="Infinity"/>

                    <!-- Vehicle image preview -->
                    <VBox alignment="CENTER" style="-fx-padding: 4 0 4 0;" spacing="4">
                        <ImageView fx:id="vehicleImageView" fitWidth="200" fitHeight="120" preserveRatio="true"/>
                        <Label fx:id="vehicleImageLabel" text="Select a vehicle to see image"
                               style="-fx-font-size: 11px; -fx-text-fill: #889AB0;"/>
                    </VBox>

                    <Label text="Customer" styleClass="form-label"/>
                    <ComboBox fx:id="customerCombo" styleClass="combo-box" promptText="Select customer" maxWidth="Infinity"/>

                    <Label text="Policy Number" styleClass="form-label"/>
                    <TextField fx:id="policyNumberField" styleClass="form-field" promptText="e.g. POL-2026-001" maxWidth="Infinity"/>

                    <Label text="Provider" styleClass="form-label"/>
                    <TextField fx:id="providerField" styleClass="form-field" promptText="Insurance provider" maxWidth="Infinity"/>

                    <Label text="Coverage Type" styleClass="form-label"/>
                    <ComboBox fx:id="coverageTypeCombo" styleClass="combo-box" promptText="Select coverage" maxWidth="Infinity"/>

                    <Label text="Start Date" styleClass="form-label"/>
                    <DatePicker fx:id="startDatePicker" styleClass="date-picker" maxWidth="Infinity"/>

                    <Label text="End Date" styleClass="form-label"/>
                    <DatePicker fx:id="endDatePicker" styleClass="date-picker" maxWidth="Infinity"/>

                    <Label text="Monthly Premium (M — Lesotho Loti)" styleClass="form-label"/>
                    <TextField fx:id="premiumField" styleClass="form-field" promptText="0.00" maxWidth="Infinity"/>

                    <Separator/>
                    <HBox spacing="8">
                        <Button fx:id="saveBtn" text="Add Policy" onAction="#handleSave" styleClass="btn-primary"/>
                        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                        <Button fx:id="clearBtn" text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
