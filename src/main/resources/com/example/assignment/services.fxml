<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.ServicesController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="Workshop — Service Records" styleClass="module-title"/>
                <Label text="Service records and vehicle maintenance history" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.62" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                </HBox>
                <TableView fx:id="serviceTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colType" text="Service Type" prefWidth="140"/>
                        <TableColumn fx:id="colDesc" text="Description" prefWidth="180"/>
                        <TableColumn fx:id="colCost" text="Cost (R)" prefWidth="90"/>
                        <TableColumn fx:id="colWorkshop" text="Workshop" prefWidth="130"/>
                    </columns>
                    <placeholder><Label text="No records found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <Label text="Details" styleClass="form-section-title"/>
                    <Label text="Vehicle" styleClass="form-label"/>
                    <ComboBox fx:id="vehicleCombo" styleClass="combo-box" promptText="Select vehicle" maxWidth="Infinity"/>
                    <Label text="Service Date" styleClass="form-label"/>
                    <DatePicker fx:id="serviceDatePicker" styleClass="date-picker" maxWidth="Infinity"/>
                    <Label text="Service Type" styleClass="form-label"/>
                    <ComboBox fx:id="serviceTypeCombo" styleClass="combo-box" promptText="Select type" maxWidth="Infinity"/>
                    <Label text="Description" styleClass="form-label"/>
                    <TextArea fx:id="descriptionArea" styleClass="form-area" promptText="Service description" prefRowCount="3"/>
                    <Label text="Cost (R)" styleClass="form-label"/>
                    <TextField fx:id="costField" styleClass="form-field" promptText="0.00" maxWidth="Infinity"/>
                    <Label text="Workshop Name" styleClass="form-label"/>
                    <TextField fx:id="workshopField" styleClass="form-field" promptText="Workshop name" maxWidth="Infinity"/>
                    <Label text="Mileage (km)" styleClass="form-label"/>
                    <TextField fx:id="mileageField" styleClass="form-field" promptText="Current mileage" maxWidth="Infinity"/>
                    <Label text="Next Service Date" styleClass="form-label"/>
                    <DatePicker fx:id="nextServiceDatePicker" styleClass="date-picker" maxWidth="Infinity"/>
                    <Separator/>
                    <HBox spacing="8">
                        <Button fx:id="saveBtn" text="Add Record" onAction="#handleSave" styleClass="btn-primary"/>
                        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                        <Button fx:id="clearBtn" text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
                    </HBox>
                    <Label fx:id="totalCostLabel" text="Total Cost: R0.00" styleClass="info-label"/>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
