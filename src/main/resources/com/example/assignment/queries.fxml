<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.QueriesController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button fx:id="backBtn" text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="Customer Queries" styleClass="module-title"/>
                <Label text="Customer Module — Questions, responses and support" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane fx:id="mainSplitPane" dividerPositions="0.62" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="refreshBtn" text="⟳ Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                </HBox>
                <TableView fx:id="queryTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colCustomer" text="Customer" prefWidth="140"/>
                        <TableColumn fx:id="colVehicle" text="Vehicle" prefWidth="120"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colQuery" text="Query" prefWidth="220"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="No records found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <ScrollPane fx:id="formPane" fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <Label text="Details" styleClass="form-section-title"/>
                    <Label text="Customer" styleClass="form-label"/>
                    <ComboBox fx:id="customerCombo" styleClass="combo-box" promptText="Select customer" maxWidth="Infinity"/>
                    <Label text="Vehicle (Optional)" styleClass="form-label"/>
                    <ComboBox fx:id="vehicleCombo" styleClass="combo-box" promptText="Select vehicle" maxWidth="Infinity"/>
                    <!-- Vehicle image preview -->
                    <VBox alignment="CENTER" spacing="4"
                          style="-fx-background-color: #F8F9FC; -fx-background-radius: 8;
                                 -fx-border-color: #E8EAEF; -fx-border-radius: 8; -fx-padding: 8;">
                        <ImageView fx:id="vehicleImageView" fitWidth="220" fitHeight="130"
                                   preserveRatio="true" smooth="true"/>
                        <Label fx:id="vehicleImageLabel" text="Select a vehicle to see image"
                               style="-fx-text-fill: #AABBCC; -fx-font-size: 11px;"/>
                    </VBox>
                    <Label text="Query Date" styleClass="form-label"/>
                    <DatePicker fx:id="queryDatePicker" styleClass="date-picker" maxWidth="Infinity"/>
                    <Label text="Query" styleClass="form-label"/>
                    <TextArea fx:id="queryTextArea" styleClass="form-area" promptText="Enter query..." prefRowCount="4"/>
                    <Label text="Response" styleClass="form-label"/>
                    <TextArea fx:id="responseTextArea" styleClass="form-area" promptText="Enter response..." prefRowCount="4"/>
                    <Label fx:id="statusLabel" text="Status" styleClass="form-label"/>
                    <ComboBox fx:id="statusCombo" styleClass="combo-box" promptText="Select status" maxWidth="Infinity"/>
                    <Separator/>
                    <HBox fx:id="actionBtnsBox" spacing="8">
                        <Button fx:id="saveBtn" text="Add Query" onAction="#handleSave" styleClass="btn-primary"/>
                        <Button fx:id="respondBtn" text="Respond" onAction="#handleRespond" styleClass="btn-success"/>
                        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                        <Button fx:id="clearBtn" text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
