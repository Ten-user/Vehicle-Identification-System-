<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.CustomersController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button fx:id="backBtn" text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="Customer Management" styleClass="module-title"/>
                <Label text="Customer Module — Vehicle owner information (Lesotho)" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane fx:id="mainSplitPane" dividerPositions="0.62" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button fx:id="refreshBtn" text="⟳ Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search customers..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                </HBox>
                <TableView fx:id="customerTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colName" text="Name" prefWidth="140"/>
                        <TableColumn fx:id="colAddress" text="Address" prefWidth="170"/>
                        <TableColumn fx:id="colPhone" text="Phone" prefWidth="130"/>
                        <TableColumn fx:id="colEmail" text="Email" prefWidth="160"/>
                        <TableColumn fx:id="colIdNumber" text="ID Number" prefWidth="120"/>
                    </columns>
                    <placeholder><Label text="No records found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <ScrollPane fx:id="formPane" fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <Label text="Customer Details" styleClass="form-section-title"/>

                    <Label text="Full Name" styleClass="form-label"/>
                    <TextField fx:id="nameField" styleClass="form-field" promptText="Full name (letters only)" maxWidth="Infinity"/>

                    <Label text="Address (Lesotho)" styleClass="form-label"/>
                    <TextField fx:id="addressField" styleClass="form-field" promptText="e.g. Maseru, Lesotho" maxWidth="Infinity"/>

                    <Label text="Phone" styleClass="form-label"/>
                    <HBox spacing="6">
                        <ComboBox fx:id="countryCodeCombo" styleClass="combo-box"
                                  prefWidth="130" style="-fx-font-size: 13px;"/>
                        <TextField fx:id="phoneField" styleClass="form-field" promptText="Phone number"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <Label text="Email" styleClass="form-label"/>
                    <TextField fx:id="emailField" styleClass="form-field" promptText="name@domain.com" maxWidth="Infinity"/>

                    <Label text="National ID Number" styleClass="form-label"/>
                    <TextField fx:id="idNumberField" styleClass="form-field" promptText="Lesotho National ID" maxWidth="Infinity"/>

                    <Separator/>
                    <HBox fx:id="actionBtnsBox" spacing="8">
                        <Button fx:id="saveBtn"   text="Add Customer"    onAction="#handleSave"   styleClass="btn-primary"/>
                        <Button fx:id="updateBtn" text="Update"          onAction="#handleUpdate" styleClass="btn-warning"/>
                        <Button fx:id="deleteBtn" text="Delete"          onAction="#handleDelete" styleClass="btn-danger"/>
                        <Button fx:id="clearBtn"  text="Clear"           onAction="#handleClear"  styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
