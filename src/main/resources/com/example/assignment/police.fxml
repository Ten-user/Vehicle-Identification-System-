<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.PoliceController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="Police Reports" styleClass="module-title"/>
                <Label text="Lesotho Police Service — Incidents, accidents and investigations" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.58" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search reports..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                </HBox>
                <TableView fx:id="reportTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colRegNumber" text="Vehicle" prefWidth="120"/>
                        <TableColumn fx:id="colType" text="Report Type" prefWidth="130"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colOfficer" text="Officer" prefWidth="140"/>
                        <TableColumn fx:id="colStation" text="Station" prefWidth="150"/>
                        <TableColumn fx:id="colCase" text="Case No." prefWidth="100"/>
                    </columns>
                    <placeholder><Label text="No records found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <Label text="Report Details" styleClass="form-section-title"/>

                    <Label text="Vehicle" styleClass="form-label"/>
                    <ComboBox fx:id="vehicleCombo" styleClass="combo-box" promptText="Select vehicle" maxWidth="Infinity"/>

                    <Label text="Report Type" styleClass="form-label"/>
                    <ComboBox fx:id="reportTypeCombo" styleClass="combo-box" promptText="Select type" maxWidth="Infinity"/>
                    <!-- Shows only when "Other" is selected -->
                    <TextField fx:id="otherTypeField" styleClass="form-field" promptText="Specify report type..."
                               maxWidth="Infinity" visible="false" managed="false"/>

                    <Label text="Report Date" styleClass="form-label"/>
                    <DatePicker fx:id="reportDatePicker" styleClass="date-picker" maxWidth="Infinity"/>

                    <Label text="Description" styleClass="form-label"/>
                    <TextArea fx:id="descriptionArea" styleClass="form-area" promptText="Report description" prefRowCount="3"/>

                    <Label text="Officer Name (auto-filled)" styleClass="form-label"/>
                    <TextField fx:id="officerField" styleClass="form-field" promptText="Officer name" maxWidth="Infinity"/>

                    <Label text="Police Station (Lesotho District)" styleClass="form-label"/>
                    <ComboBox fx:id="stationCombo" styleClass="combo-box" promptText="Select station/district" maxWidth="Infinity"/>
                    <!-- Shows only when "Other" is selected -->
                    <TextField fx:id="stationCustomField" styleClass="form-field" promptText="Enter police station name..."
                               maxWidth="Infinity" visible="false" managed="false"/>

                    <Label text="Case Number (auto-generated)" styleClass="form-label"/>
                    <TextField fx:id="caseNumberField" styleClass="form-field" promptText="CASE001" maxWidth="Infinity"/>

                    <Separator/>
                    <HBox spacing="8">
                        <Button fx:id="saveBtn" text="Add Report" onAction="#handleSave" styleClass="btn-primary"/>
                        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete" styleClass="btn-danger"/>
                        <Button fx:id="clearBtn" text="Clear" onAction="#handleClear" styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
