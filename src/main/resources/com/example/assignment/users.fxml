<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.assignment.UsersController"
            style="-fx-background-color: #F5F6FA;">
    <top>
        <HBox styleClass="module-header" alignment="CENTER_LEFT" spacing="16">
            <Button text="Back" onAction="#handleBack" styleClass="back-btn"/>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="2">
                <Label text="User Management" styleClass="module-title"/>
                <Label text="Admin Module — System access control and role management" styleClass="module-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="recordCountLabel" text="0 records" styleClass="info-label"/>
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.62" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="14" style="-fx-padding: 20; -fx-background-color: #F5F6FA;">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" styleClass="search-box" promptText="Search users..."/>
                    <Button fx:id="searchBtn" text="Search" onAction="#handleSearch" styleClass="search-btn"/>
                </HBox>
                <TableView fx:id="userTable" VBox.vgrow="ALWAYS"
                           style="-fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #E8EAEF; -fx-border-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId"       text="ID"       prefWidth="45"/>
                        <TableColumn fx:id="colUsername" text="Username" prefWidth="110"/>
                        <TableColumn fx:id="colRole"     text="Role"     prefWidth="100"/>
                        <TableColumn fx:id="colName"     text="Full Name" prefWidth="140"/>
                        <TableColumn fx:id="colEmail"    text="Email"    prefWidth="150"/>
                        <TableColumn fx:id="colPhone"    text="Phone"    prefWidth="120"/>
                        <TableColumn fx:id="colActive"   text="Status"   prefWidth="80"/>
                    </columns>
                    <placeholder><Label text="No users found" style="-fx-text-fill: #AABBCC;"/></placeholder>
                </TableView>
                <Pagination fx:id="pagination"/>
            </VBox>
            <ScrollPane fitToWidth="true" style="-fx-background-color: white;">
                <VBox spacing="12" styleClass="form-panel">
                    <Label text="User Details" styleClass="form-section-title"/>

                    <Label text="Username" styleClass="form-label"/>
                    <TextField fx:id="usernameField" styleClass="form-field" promptText="Username" maxWidth="Infinity"/>

                    <Label text="Password" styleClass="form-label"/>
                    <PasswordField fx:id="passwordField" styleClass="form-field" promptText="Password" maxWidth="Infinity"/>

                    <Label text="Role" styleClass="form-label"/>
                    <ComboBox fx:id="roleCombo" styleClass="combo-box" promptText="Select role" maxWidth="Infinity"/>

                    <Label text="Full Name" styleClass="form-label"/>
                    <TextField fx:id="fullNameField" styleClass="form-field" promptText="Full name (letters only)" maxWidth="Infinity"/>

                    <Label text="Email" styleClass="form-label"/>
                    <TextField fx:id="emailField" styleClass="form-field" promptText="name@domain.com" maxWidth="Infinity"/>

                    <Label text="Phone" styleClass="form-label"/>
                    <HBox spacing="6">
                        <ComboBox fx:id="countryCodeCombo" styleClass="combo-box"
                                  prefWidth="130" style="-fx-font-size: 13px;"/>
                        <TextField fx:id="phoneField" styleClass="form-field" promptText="Phone number"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <Separator/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button fx:id="saveBtn"         text="Register User"  onAction="#handleSave"         styleClass="btn-primary"/>
                        <Button fx:id="toggleActiveBtn" text="Toggle Active"  onAction="#handleToggleActive" styleClass="btn-warning"/>
                        <Button fx:id="deleteBtn"       text="Delete"         onAction="#handleDelete"       styleClass="btn-danger"/>
                        <Button fx:id="clearBtn"        text="Clear"          onAction="#handleClear"        styleClass="btn-secondary"/>
                    </HBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
