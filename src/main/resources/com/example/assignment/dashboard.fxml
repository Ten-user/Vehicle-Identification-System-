<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane style="-fx-background-color: #F5F6FA;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.assignment.DashboardController">
    <top>
        <VBox>
            <MenuBar fx:id="menuBar" styleClass="menu-bar" />
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="top-nav">
                <VBox spacing="2">
                    <Label styleClass="nav-system-title" text="Vehicle Identification System" />
                    <Label styleClass="nav-system-sub" text="Dashboard" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label style="-fx-font-size: 12px; -fx-text-fill: #8899AA;" text="System:" />
                    <ProgressBar fx:id="systemProgressBar" prefHeight="6" prefWidth="100" progress="0.97" />
                    <ProgressIndicator fx:id="systemProgressIndicator" prefHeight="20" prefWidth="20" />
                    <Label fx:id="systemStatusLabel" style="-fx-font-size: 12px; -fx-text-fill: #1DA462; -fx-font-weight: bold;" text="Online" />
                </HBox>
                <Separator orientation="VERTICAL" />
                <VBox alignment="CENTER_RIGHT" spacing="2">
                    <Label fx:id="welcomeLabel" styleClass="nav-user-name" text="Admin User" />
                    <Label fx:id="roleLabel" styleClass="nav-user-role" text="Administrator" />
                </VBox>
                <Button fx:id="logoutBtn" onAction="#handleLogout" styleClass="nav-logout-btn" text="Logout" />
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F5F6FA;">
            <VBox spacing="28" style="-fx-padding: 32 36 32 36;">
                <!-- Page header -->
                <VBox spacing="4">
                    <Label styleClass="page-title" text="System Modules" />
                    <Label styleClass="page-sub" text="Select a module to get started" />
                </VBox>

                <!-- Stats Row -->
                <HBox fx:id="statsRow" spacing="16">
                    <VBox fx:id="statVehiclesCard" spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="statVehicles" styleClass="stat-number" text="—" />
                        <Label styleClass="stat-label" text="Vehicles Registered" />
                    </VBox>
                    <VBox fx:id="statCustomersCard" spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="statCustomers" styleClass="stat-number" text="—" />
                        <Label styleClass="stat-label" text="Customers" />
                    </VBox>
                    <VBox fx:id="statReportsCard" spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="statReports" styleClass="stat-number" text="—" />
                        <Label styleClass="stat-label" text="Police Reports" />
                    </VBox>
                    <VBox fx:id="statViolationsCard" spacing="4" styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="statViolations" style="-fx-text-fill: #E53E3E;" styleClass="stat-number" text="—" />
                        <Label styleClass="stat-label" text="Unpaid Violations" />
                    </VBox>
                </HBox>

                <!-- Module Cards Row 1 -->
                <HBox spacing="16">
                    <VBox fx:id="vehiclesCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgVehicles" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Vehicles" />
                        <Label styleClass="module-card-sub" text="Registration and management" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="vehiclesBtn" maxWidth="Infinity" onAction="#navigateToVehicles" style="-fx-margin-top:12;" styleClass="btn-primary" text="Open Module" />
                    </VBox>

                    <VBox fx:id="customersCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgCustomers" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Customers" />
                        <Label styleClass="module-card-sub" text="Owner information and queries" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="customersBtn" maxWidth="Infinity" onAction="#navigateToCustomers" styleClass="btn-primary" text="Open Module" />
                    </VBox>

                    <VBox fx:id="servicesCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgServices" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Workshop" />
                        <Label styleClass="module-card-sub" text="Service records and history" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="servicesBtn" maxWidth="Infinity" onAction="#navigateToServices" styleClass="btn-primary" text="Open Module" />
                    </VBox>

                    <VBox fx:id="policeCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgPolice" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Police Reports" />
                        <Label styleClass="module-card-sub" text="Incidents and investigations" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="policeBtn" maxWidth="Infinity" onAction="#navigateToPolice" styleClass="btn-primary" text="Open Module" />
                    </VBox>
                </HBox>

                <!-- Module Cards Row 2 -->
                <HBox spacing="16">
                    <VBox fx:id="violationsCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgViolations" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Violations" />
                        <Label styleClass="module-card-sub" text="Traffic fines and status" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="violationsBtn" maxWidth="Infinity" onAction="#navigateToViolations" styleClass="btn-primary" text="Open Module" />
                    </VBox>

                    <VBox fx:id="insuranceCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgInsurance" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Insurance" />
                        <Label styleClass="module-card-sub" text="Policy management and tracking" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="insuranceBtn" maxWidth="Infinity" onAction="#navigateToInsurance" styleClass="btn-primary" text="Open Module" />
                    </VBox>

                    <VBox fx:id="queriesCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgQueries" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="Queries" />
                        <Label styleClass="module-card-sub" text="Customer questions and responses" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="queriesBtn" maxWidth="Infinity" onAction="#navigateToQueries" styleClass="btn-primary" text="Open Module" />
                    </VBox>

                    <VBox fx:id="usersCard" alignment="TOP_CENTER" spacing="0" styleClass="module-card" HBox.hgrow="ALWAYS">
                        <ImageView fx:id="imgUsers" fitHeight="70" fitWidth="70" preserveRatio="true" smooth="true" />
                        <Region prefHeight="10" />
                        <Label styleClass="module-card-title" text="User Management" />
                        <Label styleClass="module-card-sub" text="Access control and roles" />
                        <Region VBox.vgrow="ALWAYS" />
                        <Button fx:id="usersBtn" maxWidth="Infinity" onAction="#navigateToUsers" styleClass="btn-primary" text="Open Module" />
                    </VBox>
                </HBox>

                <HBox alignment="CENTER">
                    <Label style="-fx-font-size: 11px; -fx-text-fill: #AABBCC;" text="VIS — Vehicle Identification System   |  Limkwing University of Creative Technology" />
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
