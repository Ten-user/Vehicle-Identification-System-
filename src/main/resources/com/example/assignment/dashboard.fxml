<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="rootContainer" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.assignment.DashboardController"
      spacing="0" style="-fx-background-color: #f0f2f5;">

    <!-- Menu Bar (built programmatically in controller) -->
    <MenuBar fx:id="menuBar"/>

    <!-- Header -->
    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 20 30 20 30;" alignment="CENTER_LEFT" spacing="20">
        <Label text="🚗" style="-fx-font-size: 36px;"/>
        <VBox spacing="4">
            <Label fx:id="welcomeLabel" text="Welcome" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="roleLabel" text="" style="-fx-font-size: 13px; -fx-text-fill: #95a5a6;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <VBox alignment="CENTER_RIGHT" spacing="4">
            <Label fx:id="systemStatusLabel" text="System Status: Online" style="-fx-text-fill: #2ecc71; -fx-font-size: 12px;"/>
            <ProgressBar fx:id="systemProgressBar" prefWidth="160" prefHeight="12"/>
        </VBox>
        <ProgressIndicator fx:id="systemProgressIndicator" prefWidth="36" prefHeight="36"/>
    </HBox>

    <!-- Module Buttons Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-padding: 20;">
        <VBox spacing="20" style="-fx-padding: 10;">
            <Label text="System Modules" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <TilePane hgap="16" vgap="16" prefColumns="4">
                <Button fx:id="vehiclesBtn"   text="🚗 Vehicles"        onAction="#navigateToVehicles"   styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="customersBtn"  text="👤 Customers"       onAction="#navigateToCustomers"  styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="servicesBtn"   text="🔧 Service Records" onAction="#navigateToServices"   styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="policeBtn"     text="👮 Police Reports"  onAction="#navigateToPolice"     styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="violationsBtn" text="⚠️ Violations"      onAction="#navigateToViolations" styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="insuranceBtn"  text="🛡️ Insurance"       onAction="#navigateToInsurance"  styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #d35400; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="queriesBtn"    text="💬 Queries"         onAction="#navigateToQueries"    styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
                <Button fx:id="usersBtn"      text="⚙️ User Management" onAction="#navigateToUsers"      styleClass="module-btn" prefWidth="170" prefHeight="90"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </TilePane>
        </VBox>
    </ScrollPane>

    <!-- Footer -->
    <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 10 20 10 20; -fx-border-color: #bdc3c7; -fx-border-width: 1 0 0 0;" alignment="CENTER_LEFT" spacing="20">
        <Label text="Vehicle Identification System v1.0 | OOP2 2026" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12px;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="logoutBtn" text="🚪 Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 12px;
                       -fx-padding: 6 14 6 14; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>
</VBox>
